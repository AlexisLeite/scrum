generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  platform_admin
  product_owner
  scrum_master
  team_member
  viewer
}

enum StoryStatus {
  DRAFT
  READY
  IN_SPRINT
  DONE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ActivityEntityType {
  AUTH
  USER
  TEAM
  PRODUCT
  STORY
  TASK
  SPRINT
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  avatarUrl     String?
  role          Role           @default(team_member)
  passwordHash  String?
  gitlabId      String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  teamMembers   TeamMember[]
  productMember ProductMember[]
  tasks         Task[]         @relation("TaskAssignee")
  productsOwned Product[]      @relation("ProductOwner")
  activityLogsAsActor ActivityLog[] @relation("ActivityActor")
}

model Team {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  sprints     Sprint[]
  productLinks ProductTeam[]
  activityLogs ActivityLog[]
}

model TeamMember {
  teamId     String
  userId     String
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  key         String          @unique
  description String?
  ownerId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  owner       User            @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     ProductMember[]
  stories     UserStory[]
  sprints     Sprint[]
  workflow    WorkflowColumn[]
  tasks       Task[]
  teamLinks   ProductTeam[]
  activityLogs ActivityLog[]

  @@index([ownerId])
}

model ProductMember {
  productId   String
  userId      String
  role        Role
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([productId, userId])
}

model ProductTeam {
  productId  String
  teamId     String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([productId, teamId])
  @@index([teamId])
}

model WorkflowColumn {
  id          String   @id @default(cuid())
  productId   String
  name        String
  sortOrder   Int
  isDone      Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@unique([productId, sortOrder])
}

model Sprint {
  id          String       @id @default(cuid())
  productId   String
  teamId      String
  name        String
  goal        String?
  startDate   DateTime?
  endDate     DateTime?
  status      SprintStatus @default(PLANNED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  tasks       Task[]

  @@index([productId])
  @@index([teamId])
  @@index([status])
}

model UserStory {
  id           String      @id @default(cuid())
  productId    String
  title        String
  description  String?
  storyPoints  Int
  status       StoryStatus @default(DRAFT)
  backlogRank  Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([productId, backlogRank])
}

model Task {
  id              String      @id @default(cuid())
  storyId          String
  productId        String
  sprintId         String?
  assigneeId       String?
  title            String
  description      String?
  status           String
  boardOrder       Int         @default(0)
  effortPoints     Int?
  estimatedHours   Float?
  remainingHours   Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  story            UserStory   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sprint           Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee         User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  statusHistory    TaskStatusHistory[]

  @@index([storyId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([sprintId, status, boardOrder])
}

model TaskStatusHistory {
  id          String   @id @default(cuid())
  taskId       String
  fromStatus   String?
  toStatus     String
  changedAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, changedAt])
}

model ActivityLog {
  id          String             @id @default(cuid())
  actorUserId String?
  teamId      String?
  productId   String?
  entityType  ActivityEntityType
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  metadataJson Json?
  createdAt   DateTime           @default(now())
  actorUser   User?              @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  team        Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  product     Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([teamId, createdAt])
  @@index([productId, createdAt])
}

model SprintMetricDaily {
  id               String   @id @default(cuid())
  sprintId          String
  date              DateTime
  completedPoints   Int
  scopePoints       Int
  remainingPoints   Int

  @@unique([sprintId, date])
  @@index([sprintId])
}
