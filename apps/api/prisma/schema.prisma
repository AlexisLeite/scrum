generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  platform_admin
  product_owner
  scrum_master
  team_member
}

enum StoryStatus {
  DRAFT
  READY
  IN_SPRINT
  DONE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ActivityEntityType {
  AUTH
  USER
  TEAM
  PRODUCT
  STORY
  TASK
  SPRINT
}

enum DraftEntityType {
  PRODUCT
  STORY
  TASK
  TASK_MESSAGE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  avatarUrl     String?
  role          Role           @default(team_member)
  passwordHash  String?
  gitlabId      String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  teamMembers   TeamMember[]
  productMember ProductMember[]
  tasks         Task[]         @relation("TaskAssignee")
  taskMessages  TaskMessage[]  @relation("TaskMessageAuthor")
  productsOwned Product[]      @relation("ProductOwner")
  activityLogsAsActor ActivityLog[] @relation("ActivityActor")
  apiKeys       ApiKey[]
  drafts        UserDraft[]
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  name       String
  prefix     String
  keyHash    String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Team {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  sprints     Sprint[]
  productLinks ProductTeam[]
  activityLogs ActivityLog[]
}

model TeamMember {
  teamId     String
  userId     String
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  key         String          @unique
  description String?
  ownerId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  owner       User            @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     ProductMember[]
  stories     UserStory[]
  sprints     Sprint[]
  workflow    WorkflowColumn[]
  tasks       Task[]
  teamLinks   ProductTeam[]
  activityLogs ActivityLog[]

  @@index([ownerId])
}

model ProductMember {
  productId   String
  userId      String
  role        Role
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([productId, userId])
}

model ProductTeam {
  productId  String
  teamId     String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([productId, teamId])
  @@index([teamId])
}

model WorkflowColumn {
  id          String   @id @default(cuid())
  productId   String
  name        String
  sortOrder   Int
  isDone      Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@unique([productId, sortOrder])
}

model Sprint {
  id          String       @id @default(cuid())
  productId   String
  teamId      String
  name        String
  goal        String?
  startDate   DateTime?
  endDate     DateTime?
  status      SprintStatus @default(PLANNED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  tasks       Task[]
  unfinishedTasks TaskUnfinishedSprint[]

  @@index([productId])
  @@index([teamId])
  @@index([status])
}

model UserStory {
  id           String      @id @default(cuid())
  productId    String
  title        String
  description  String?
  storyPoints  Int
  status       StoryStatus @default(DRAFT)
  backlogRank  Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([productId, backlogRank])
}

model Task {
  id              String      @id @default(cuid())
  storyId          String
  productId        String
  sprintId         String?
  assigneeId       String?
  parentTaskId     String?
  sourceMessageId  String?
  title            String
  description      String?
  status           String
  boardOrder       Int         @default(0)
  effortPoints     Int?
  estimatedHours   Float?
  remainingHours   Float?
  actualHours      Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  story            UserStory   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sprint           Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee         User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parentTask       Task?       @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks       Task[]      @relation("TaskHierarchy")
  sourceMessage    TaskMessage? @relation("TaskSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  messages         TaskMessage[]
  statusHistory    TaskStatusHistory[]
  unfinishedSprintSnapshots TaskUnfinishedSprint[]

  @@index([storyId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([sourceMessageId])
  @@index([sprintId, status, boardOrder])
}

model TaskUnfinishedSprint {
  id             String    @id @default(cuid())
  taskId         String?
  sprintId       String
  title          String
  description    String?
  status         String
  boardOrder     Int
  storyId        String?
  storyTitle     String?
  assigneeId     String?
  assigneeName   String?
  effortPoints   Int?
  estimatedHours Float?
  actualHours    Float?
  recordedAt     DateTime  @default(now())
  task           Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  sprint         Sprint    @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@unique([taskId, sprintId])
  @@index([taskId])
  @@index([sprintId, status, boardOrder])
}

model TaskStatusHistory {
  id          String   @id @default(cuid())
  taskId       String
  fromStatus   String?
  toStatus     String
  changedAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, changedAt])
}

model TaskMessage {
  id              String      @id @default(cuid())
  taskId          String
  authorUserId    String?
  parentMessageId String?
  body            String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  task            Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUser      User?       @relation("TaskMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  parentMessage   TaskMessage? @relation("TaskMessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         TaskMessage[] @relation("TaskMessageThread")
  derivedTasks    Task[]      @relation("TaskSourceMessage")

  @@index([taskId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([parentMessageId, createdAt])
}

model ActivityLog {
  id          String             @id @default(cuid())
  actorUserId String?
  teamId      String?
  productId   String?
  entityType  ActivityEntityType
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  metadataJson Json?
  createdAt   DateTime           @default(now())
  actorUser   User?              @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  team        Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  product     Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([teamId, createdAt])
  @@index([productId, createdAt])
}

model SprintMetricDaily {
  id               String   @id @default(cuid())
  sprintId          String
  date              DateTime
  completedPoints   Int
  scopePoints       Int
  remainingPoints   Int

  @@unique([sprintId, date])
  @@index([sprintId])
}

model UserDraft {
  id               String          @id @default(cuid())
  userId           String
  entityType       DraftEntityType
  entityId         String
  productId        String?
  payloadJson      Json
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([userId, entityType, entityId])
  @@index([userId, updatedAt])
  @@index([entityType, entityId, updatedAt])
  @@index([productId, updatedAt])
}
