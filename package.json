{
  "name": "scrum-platform",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "pnpm db:push && pnpm db:generate && pnpm db:seed && turbo run dev --parallel",
    "build": "turbo run build",
    "build-dev-mode": "BUILD_DEV_MODE=1 turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "node scripts/run-with-env.mjs pnpm --filter @scrum/api prisma:generate",
    "db:migrate": "pnpm --filter @scrum/api prisma:migrate",
    "db:push": "node scripts/run-with-env.mjs pnpm --filter @scrum/api prisma:push",
    "db:seed": "node scripts/run-with-env.mjs pnpm --filter @scrum/api prisma:seed",
    "test:e2e:critical": "node scripts/e2e-critical-workflows.mjs",
    "test:e2e:domain": "node scripts/e2e-domain-coverage.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
